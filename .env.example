# Optional. Without this key, FinGuard AI uses a deterministic local explanation.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated origins allowed to call the API from a browser.
# Only needed for local development (the Vite dev server on :5173).
# In production the React frontend is served from the same origin, so CORS is not needed.
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:5173

# Optional absolute model directory. Defaults to ./models.
FINGUARD_MODEL_DIR=
